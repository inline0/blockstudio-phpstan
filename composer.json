{
  "name": "blockstudio/phpstan",
  "description": "PHPStan extension for Blockstudio with template typing, schema validation, block tag checks, and public API stubs.",
  "type": "phpstan-extension",
  "license": "MIT",
  "keywords": [
    "blockstudio",
    "phpstan",
    "wordpress",
    "gutenberg",
    "static-analysis"
  ],
  "homepage": "https://blockstudio.dev/docs/dev/phpstan",
  "support": {
    "docs": "https://blockstudio.dev/docs/dev/phpstan",
    "issues": "https://github.com/inline0/blockstudio/issues",
    "source": "https://github.com/inline0/blockstudio-phpstan"
  },
  "require": {
    "php": "^8.2",
    "phpstan/phpstan": "^2.0",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "nikic/php-parser": "^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Blockstudio\\PHPStan\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Blockstudio\\PHPStan\\Tests\\": "tests/"
    }
  },
  "extra": {
    "phpstan": {
      "includes": [
        "extension.neon"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "stable"
}
